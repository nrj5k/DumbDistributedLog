use std::net::{IpAddr, Ipv4Addr, SocketAddr};
use std::time::{Duration, Instant};
use thiserror::Error;

/// Core transport errors shared by both planes
#[derive(Error, Debug, Clone)]
pub enum TransportError {
    #[error("Connection lost to {remote_addr}")]
    ConnectionLost { remote_addr: SocketAddr },

    #[error("Network unreachable")]
    NetworkUnreachable,

    #[error("Transport shutdown")]
    TransportShutdown,

    #[error("Serialization error")]
    SerializationError,

    #[error("Timeout after {duration:?}")]
    Timeout { duration: Duration },

    #[error("Buffer overflow: size {size}")]
    BufferOverflow { size: usize },
}
/// Foundation trait shared by both control and data planes
pub trait Transport: Send + Sync {
    /// Local socket address
    fn local_addr(&self) -> SocketAddr;

    /// Remote socket address  
    fn remote_addr(&self) -> SocketAddr;

    /// Connection health status
    fn is_connected(&self) -> bool;

    /// Graceful shutdown
    fn close(&mut self) -> Result<(), TransportError>;

    /// Connection health check
    fn health_check(&self) -> HealthStatus;

    /// Transport statistics
    fn stats(&self) -> TransportStats;
}
/// Control plane - reliable coordination, small messages
pub trait ControlPlaneTransport: Transport {
    /// Send control message (fire and forget)
    fn send_control(&mut self, message: ControlMessage) -> Result<(), TransportError>;

    /// Receive control message
    fn recv_control(&mut self) -> Result<ControlMessage, TransportError>;

    /// Send and wait for response (request/response pattern)
    fn send_control_and_wait(
        &mut self,
        message: ControlMessage,
    ) -> Result<ControlResponse, TransportError>;

    /// Get current retry configuration
    fn max_retries(&self) -> u32;

    /// Get timeout configuration
    fn timeout_duration(&self) -> Duration;
}
/// Data plane - high-throughput streaming, large payloads
pub trait DataPlaneTransport: Transport {
    /// Send data stream
    fn send_data(&mut self, stream_id: StreamId, data: DataPayload) -> Result<(), TransportError>;

    /// Receive data stream
    fn recv_data(&mut self, stream_id: StreamId) -> Result<DataPayload, TransportError>;

    /// Get streaming sender for large payloads
    fn data_sender(&self, stream_id: StreamId) -> Box<dyn DataSender>;

    /// Get streaming receiver for large payloads
    fn data_receiver(&self, stream_id: StreamId) -> Box<dyn DataReceiver>;

    /// Adjust send buffer size
    fn set_send_buffer_size(&mut self, size: usize);

    /// Adjust receive buffer size
    fn set_recv_buffer_size(&mut self, size: usize);

    /// Current backpressure level
    fn current_backpressure(&self) -> BackpressureLevel;
}
/// Factory for creating plane-specific transports
pub trait TransportFactory: Send + Sync {
    type ControlTransport: ControlPlaneTransport;
    type DataTransport: DataPlaneTransport;

    /// Create control transport from shared connection
    fn create_control_transport(&self) -> Result<Self::ControlTransport, FactoryError>;

    /// Create data transport from shared connection
    fn create_data_transport(&self) -> Result<Self::DataTransport, FactoryError>;
}
// Supporting types
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub struct StreamId(pub u64);
#[derive(Debug, Clone)]
pub struct HealthStatus {
    pub is_healthy: bool,
    pub last_check: Instant,
    pub error_count: u64,
    pub response_time: Duration,
}
#[derive(Debug, Clone)]
pub struct TransportStats {
    pub bytes_sent: u64,
    pub bytes_received: u64,
    pub messages_sent: u64,
    pub messages_received: u64,
    pub connection_duration: Duration,
}
#[derive(Debug, Clone)]
pub enum BackpressureLevel {
    Normal,
    Elevated,
    Critical,
}
/// Control plane message types
#[derive(Debug, Clone)]
pub enum ControlMessage {
    RaftVote { term: u64, candidate_id: NodeId },
    RaftHeartbeat { term: u64, leader_id: NodeId },
    GlobalVariableUpdate { name: String, value: f64 },
    QueueStatusRequest { queue_name: String },
    HealthCheck { node_id: NodeId },
}
/// Control plane response types
#[derive(Debug, Clone)]
pub enum ControlResponse {
    Ack,
    Nak { reason: String },
    Data { payload: Vec<u8> },
}
/// Data plane payload
#[derive(Debug, Clone)]
pub struct DataPayload {
    pub stream_id: StreamId,
    pub sequence: u64,
    pub timestamp: Instant,
    pub data: Vec<u8>,
}
/// Streaming interfaces for large data
pub trait DataSender: Send + Sync {
    fn send_chunk(&mut self, chunk: Vec<u8>) -> Result<(), TransportError>;
    fn flush(&mut self) -> Result<(), TransportError>;
    fn buffer_size(&self) -> usize;
}
pub trait DataReceiver: Send + Sync {
    fn recv_chunk(&mut self) -> Result<Option<Vec<u8>>, TransportError>;
    fn complete(&mut self) -> Result<Vec<u8>, TransportError>;
    fn is_complete(&self) -> bool;
}
#[derive(Debug, Clone)]
pub struct NodeId(pub String);
impl From<&str> for NodeId {
    fn from(s: &str) -> Self {
        NodeId(s.to_string())
    }
}
/// Factory errors
#[derive(Error, Debug)]
pub enum FactoryError {
    #[error("Connection establishment failed: {reason}")]
    ConnectionFailed { reason: String },

    #[error("Configuration error: {issue}")]
    ConfigurationError { issue: String },

    #[error("Resource unavailable: {resource}")]
    ResourceUnavailable { resource: String },
}

// Mock implementations for testing
struct MockTransport;
struct MockControlTransport;
struct MockDataTransport;

impl Transport for MockTransport {
    fn local_addr(&self) -> SocketAddr {
        SocketAddr::new(IpAddr::V4(Ipv4Addr::new(127, 0, 0, 1)), 8080)
    }

    fn remote_addr(&self) -> SocketAddr {
        SocketAddr::new(IpAddr::V4(Ipv4Addr::new(127, 0, 0, 2)), 8081)
    }

    fn is_connected(&self) -> bool {
        true
    }

    fn close(&mut self) -> Result<(), TransportError> {
        Ok(())
    }

    fn health_check(&self) -> HealthStatus {
        HealthStatus {
            is_healthy: true,
            last_check: Instant::now(),
            error_count: 0,
            response_time: Duration::from_millis(5),
        }
    }

    fn stats(&self) -> TransportStats {
        TransportStats {
            bytes_sent: 1024,
            bytes_received: 2048,
            messages_sent: 10,
            messages_received: 20,
            connection_duration: Duration::from_secs(60),
        }
    }
}

impl ControlPlaneTransport for MockControlTransport {
    fn send_control(&mut self, message: ControlMessage) -> Result<(), TransportError> {
        // Mock control message handling
        Ok(())
    }

    fn recv_control(&mut self) -> Result<ControlMessage, TransportError> {
        Ok(ControlMessage::HealthCheck {
            node_id: NodeId("test-node".to_string()),
        })
    }

    fn send_control_and_wait(
        &mut self,
        message: ControlMessage,
    ) -> Result<ControlResponse, TransportError> {
        Ok(ControlResponse::Ack)
    }

    fn max_retries(&self) -> u32 {
        3
    }

    fn timeout_duration(&self) -> Duration {
        Duration::from_secs(5)
    }
}

impl Transport for MockControlTransport {
    fn local_addr(&self) -> SocketAddr {
        SocketAddr::new(IpAddr::V4(Ipv4Addr::new(127, 0, 0, 1)), 8080)
    }

    fn remote_addr(&self) -> SocketAddr {
        SocketAddr::new(IpAddr::V4(Ipv4Addr::new(127, 0, 0, 2)), 8081)
    }

    fn is_connected(&self) -> bool {
        true
    }

    fn close(&mut self) -> Result<(), TransportError> {
        Ok(())
    }

    fn health_check(&self) -> HealthStatus {
        HealthStatus {
            is_healthy: true,
            last_check: Instant::now(),
            error_count: 0,
            response_time: Duration::from_millis(3),
        }
    }

    fn stats(&self) -> TransportStats {
        TransportStats {
            bytes_sent: 512,
            bytes_received: 1024,
            messages_sent: 5,
            messages_received: 8,
            connection_duration: Duration::from_secs(30),
        }
    }
}

#[test]
fn test_transport_basic_functionality() {
    let transport = MockTransport;

    assert_eq!(transport.local_addr().port(), 8080);
    assert_eq!(transport.remote_addr().port(), 8081);
    assert!(transport.is_connected());
    assert!(transport.close().is_ok());

    let health = transport.health_check();
    assert!(health.is_healthy);
    assert_eq!(health.error_count, 0);
    assert!(health.response_time.as_millis() < 10);
}

#[test]
fn test_transport_stats() {
    let transport = MockTransport;
    let stats = transport.stats();

    assert_eq!(stats.bytes_sent, 1024);
    assert_eq!(stats.bytes_received, 2048);
    assert_eq!(stats.messages_sent, 10);
    assert_eq!(stats.messages_received, 20);
    assert!(stats.connection_duration.as_secs() > 0);
}

#[test]
fn test_control_plane_messages() {
    let mut control = MockControlTransport;

    let vote_message = ControlMessage::RaftVote {
        term: 1,
        candidate_id: NodeId::from("candidate-1"),
    };

    assert!(control.send_control(vote_message).is_ok());

    let received = control.recv_control();
    assert!(received.is_ok());
    match received.unwrap() {
        ControlMessage::HealthCheck { node_id } => {
            assert_eq!(node_id.0, "test-node");
        }
        _ => panic!("Unexpected message type"),
    }

    assert_eq!(control.max_retries(), 3);
    assert_eq!(control.timeout_duration(), Duration::from_secs(5));
}

#[test]
fn test_control_plane_request_response() {
    let mut control = MockControlTransport;

    let heartbeat = ControlMessage::RaftHeartbeat {
        term: 1,
        leader_id: NodeId::from("leader-1"),
    };

    let response = control.send_control_and_wait(heartbeat);
    assert!(response.is_ok());
    match response.unwrap() {
        ControlResponse::Ack => {
            // Expected response
        }
        _ => panic!("Unexpected response type"),
    }
}

#[test]
fn test_node_id_creation() {
    let node_id = NodeId::from("test-node");
    assert_eq!(node_id.0, "test-node");
}

#[test]
fn test_backpressure_levels() {
    assert_eq!(BackpressureLevel::Normal as u8, 0);
    assert_eq!(BackpressureLevel::Elevated as u8, 1);
    assert_eq!(BackpressureLevel::Critical as u8, 2);
}

#[test]
fn test_transport_error_display() {
    let error = TransportError::ConnectionLost {
        remote_addr: SocketAddr::new(IpAddr::V4(Ipv4Addr::new(192, 168, 1, 100)), 8080),
    };

    assert_eq!(error.to_string(), "Connection lost to 192.168.1.100:8080");

    let timeout_error = TransportError::Timeout {
        duration: Duration::from_secs(5),
    };

    assert!(timeout_error.to_string().contains("Timeout after 5s"));
}

#[test]
fn test_health_status_timing() {
    let now = Instant::now();
    let health = HealthStatus {
        is_healthy: false,
        last_check: now,
        error_count: 5,
        response_time: Duration::from_millis(50),
    };

    assert!(!health.is_healthy);
    assert_eq!(health.error_count, 5);
    assert_eq!(health.response_time.as_millis(), 50);
}
