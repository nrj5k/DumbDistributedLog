//! Test utilities for autoqueues library
//!
//! Common helper functions and types used across different test modules

use std::sync::Arc;
use autoqueues::*;
use tokio::time::Duration;

/// Create a basic sensor queue for testing
pub fn create_sensor_queue(name: &str, interval_ms: u64) -> Queue<i32> {
    let name_owned = name.to_string();
    let hook = create_test_hook(&name_owned);
    let queue_type = QueueType::new(
        QueueValue::NodeAvailability,
        interval_ms,
        2,
        format!("{}_trace.log", name),
        format!("{}_var", name),
    );
    let config = QueueConfig::new(Mode::Sensor, hook, Model::Linear, queue_type);
    Queue::new(config)
}

/// Create a basic insight queue for testing
pub fn create_insight_queue(name: &str, interval_ms: u64) -> Queue<String> {
    let name_owned = name.to_string();
    let hook: FunctionHook<String> = Arc::new(move |_| Ok(format!("Insight from {}", name_owned)));
    let queue_type = QueueType::new(
        QueueValue::NodeLoad,
        interval_ms,
        2,
        format!("{}_trace.log", name),
        format!("{}_var", name),
    );
    let config = QueueConfig::new(Mode::Insight, hook, Model::Linear, queue_type);
    Queue::new(config)
}

